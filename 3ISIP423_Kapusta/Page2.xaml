<Page x:Class="_3ISIP423_Kapusta.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 2" Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Функция 2: Кусочная функция" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,0,20" Background="White">
                <Image Source="/Images/formula2.png" Height="150" Stretch="Uniform" 
           ToolTip="Кусочная функция с выбором f(x)"/>
            </Border>

            <!-- Панель ввода данных -->
            <GroupBox Header="Ввод данных" Margin="0,0,0,20" Padding="10">
                <StackPanel>

                    <!-- Ввод x -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="x =" Width="50" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="txtX2" Width="150" Margin="10,0" 
                                 ToolTip="Введите значение x" FontSize="16"/>
                    </StackPanel>

                    <!-- Ввод y -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="y =" Width="50" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="txtY2" Width="150" Margin="10,0" 
                                 ToolTip="Введите значение y" FontSize="16"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- Выбор функции f(x) -->
            <GroupBox Header="Выбор функции f(x)" Margin="0,0,0,20" Padding="10">
                <StackPanel>
                    <RadioButton x:Name="rbtnSh" Content="sh(x) - гиперболический синус" 
                                 GroupName="fx" IsChecked="True" Margin="5"
                                 ToolTip="f(x) = sh(x) = (e^x - e^(-x))/2"/>
                    <RadioButton x:Name="rbtnX2" Content="x² - квадрат x" 
                                 GroupName="fx" Margin="5"
                                 ToolTip="f(x) = x²"/>
                    <RadioButton x:Name="rbtnExp" Content="e^x - экспонента" 
                                 GroupName="fx" Margin="5"
                                 ToolTip="f(x) = e^x"/>
                </StackPanel>
            </GroupBox>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Вычислить" Width="120" Height="40" Margin="10" 
                        Click="btnCalculate2_Click" Background="#4CAF50" Foreground="White"
                        ToolTip="Рассчитать значение функции"/>
                <Button Content="Очистить" Width="120" Height="40" Margin="10" 
                        Click="btnClear2_Click" Background="#F44336" Foreground="White"
                        ToolTip="Очистить все поля"/>
            </StackPanel>

            <!-- Результат -->
            <GroupBox Header="Результат" Padding="10">
                <StackPanel>
                    <TextBlock Text="d =" FontSize="16" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtResult2" IsReadOnly="True" 
                             Background="#FFF9C4" FontSize="18" FontWeight="Bold" 
                             Height="40" TextAlignment="Center"
                             ToolTip="Результат вычислений"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Page>