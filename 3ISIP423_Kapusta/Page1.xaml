<Page x:Class="_3ISIP423_Kapusta.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 1" Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Функция 1: Степенно-тригонометрическое выражение" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- поправила  -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,0,20" Background="White">
                <Image Source="/Images/formula1.png" Height="150" Stretch="Uniform" 
           ToolTip="Формула: w = |cos x - cos y|^(1+2sin²y) * (1 + z + z²/2 + z³/3 + z⁴/4)"/>
            </Border>

            <!-- тут ок -->
            <GroupBox Header="Ввод данных" Margin="0,0,0,20" Padding="10">
                <StackPanel>

                    <!-- Ввод x -->
                    <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
                        <TextBlock Text="x =" Width="50" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="txtX" Width="150" Margin="10,0" 
                                 ToolTip="Введите значение x (например: 1.5 или -2.3)" 
                                 VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>

                    <!-- Ввод y -->
                    <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
                        <TextBlock Text="y =" Width="50" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="txtY" Width="150" Margin="10,0" 
                                 ToolTip="Введите значение y (например: 0.5)" 
                                 VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>

                    <!-- Ввод z -->
                    <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
                        <TextBlock Text="z =" Width="50" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox x:Name="txtZ" Width="150" Margin="10,0" 
                                 ToolTip="Введите значение z (например: 2.0)" 
                                 VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <!-- Кнопки управления -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button x:Name="btnCalculate1" Content="Вычислить" Width="120" Height="40" 
                        Margin="10" Click="btnCalculate1_Click" 
                        ToolTip="Рассчитать значение функции" 
                        Background="#4CAF50" Foreground="White" FontSize="14"/>

                <Button x:Name="btnClear1" Content="Очистить" Width="120" Height="40" 
                        Margin="10" Click="btnClear1_Click" 
                        ToolTip="Очистить все поля" 
                        Background="#F44336" Foreground="White" FontSize="14"/>
            </StackPanel>

            <!-- Результат -->
            <GroupBox Header="Результат" Padding="10">
                <StackPanel>
                    <TextBlock Text="w =" FontSize="16" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtResult1" IsReadOnly="True" 
                             Background="#FFF9C4" FontSize="18" FontWeight="Bold" 
                             Height="40" TextAlignment="Center"
                             ToolTip="Результат вычислений"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Page>