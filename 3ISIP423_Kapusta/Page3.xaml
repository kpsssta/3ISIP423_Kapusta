<Page x:Class="_3ISIP423_Kapusta.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      Title="Страница 3" Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Функция 3: y = a·x³ + cos²(x³ - b)" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,0,20" Background="White">
                <Image Source="/Images/formula3.png" Height="120" Stretch="Uniform" 
           ToolTip="y = a·x³ + cos²(x³ - b)"/>
            </Border>

            <!-- Параметры функции и табуляции -->
            <GroupBox Header="Параметры" Margin="0,0,0,20" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Параметры функции -->
                    <TextBlock Text="a =" Grid.Row="0" Grid.Column="0" 
                               VerticalAlignment="Center" FontSize="14" Margin="5"/>
                    <TextBox x:Name="txtA" Grid.Row="0" Grid.Column="1" 
                             Width="100" Margin="5" Text="1"
                             ToolTip="Коэффициент a"/>

                    <TextBlock Text="b =" Grid.Row="0" Grid.Column="2" 
                               VerticalAlignment="Center" FontSize="14" Margin="5"/>
                    <TextBox x:Name="txtB" Grid.Row="0" Grid.Column="3" 
                             Width="100" Margin="5" Text="0"
                             ToolTip="Параметр b"/>

                    <!-- Параметры табуляции -->
                    <TextBlock Text="x₀ =" Grid.Row="1" Grid.Column="0" 
                               VerticalAlignment="Center" FontSize="14" Margin="5"/>
                    <TextBox x:Name="txtX0" Grid.Row="1" Grid.Column="1" 
                             Width="100" Margin="5" Text="-2"
                             ToolTip="Начальное значение x"/>

                    <TextBlock Text="xₖ =" Grid.Row="1" Grid.Column="2" 
                               VerticalAlignment="Center" FontSize="14" Margin="5"/>
                    <TextBox x:Name="txtXk" Grid.Row="1" Grid.Column="3" 
                             Width="100" Margin="5" Text="2"
                             ToolTip="Конечное значение x"/>

                    <TextBlock Text="dx =" Grid.Row="2" Grid.Column="0" 
                               VerticalAlignment="Center" FontSize="14" Margin="5"/>
                    <TextBox x:Name="txtDx" Grid.Row="2" Grid.Column="1" 
                             Width="100" Margin="5" Text="0.1"
                             ToolTip="Шаг табуляции"/>
                </Grid>
            </GroupBox>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Вычислить" Width="120" Height="40" Margin="10" 
                        Click="btnCalculate3_Click" Background="#4CAF50" Foreground="White"
                        ToolTip="Построить таблицу и график"/>
                <Button Content="Очистить" Width="120" Height="40" Margin="10" 
                        Click="btnClear3_Click" Background="#F44336" Foreground="White"
                        ToolTip="Очистить все поля"/>
            </StackPanel>

            <!-- Таблица результатов -->
            <GroupBox Header="Таблица значений" Margin="0,0,0,20" Padding="10">
                <StackPanel>
                    <TextBlock Text="x          y" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtResults" Height="150" 
                             IsReadOnly="True" AcceptsReturn="True" 
                             TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Courier New" Background="#FFF9C4"
                             ToolTip="Результаты вычислений"/>
                </StackPanel>
            </GroupBox>

            <!-- ГРАФИК -->
            <GroupBox Header="График функции" Padding="10">
                <oxy:PlotView x:Name="plotView" Height="300" Margin="5"/>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Page>